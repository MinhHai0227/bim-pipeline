# Application configuration settings
APP_NAME=BIM Pipeline API
ENVIRONMENT=local
API_PORT=8000

# Database configuration
POSTGRES_PORT=5432
POSTGRES_DB=bim_pipeline
POSTGRES_USER=bim_user
POSTGRES_PASSWORD=change_me

# Optional. If set, this overrides the POSTGRES_* values above.
# Example: postgresql+psycopg://bim_user:change_me@localhost:5432/bim_pipeline
DATABASE_URL=

# IFC import configuration
MAX_IFC_UPLOAD_SIZE_MB=500
TMP_IFC_DIR=data/tmp/ifc

# Background worker configuration
# Local host values are used when API/worker run outside Docker.
# Docker Compose overrides these with internal service hosts.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Fragment conversion worker
# Local example: http://localhost:8090
# Docker Compose overrides this to http://fragment-worker:8090 for the Python worker.
FRAGMENT_WORKER_PORT=8090
FRAGMENT_WORKER_URL=
FRAGMENT_WORKER_TIMEOUT_SECONDS=900

# Autodesk APS / Model Derivative
# Required only when uploading .rvt and exporting it to IFC.
AUTODESK_CLIENT_ID=
AUTODESK_CLIENT_SECRET=
AUTODESK_BUCKET_KEY=
AUTODESK_SCOPES=data:read data:write data:create bucket:create bucket:read
AUTODESK_TOKEN_URL=https://developer.api.autodesk.com/authentication/v2/token
AUTODESK_OSS_BASE_URL=https://developer.api.autodesk.com/oss/v2
AUTODESK_MODEL_DERIVATIVE_BASE_URL=https://developer.api.autodesk.com/modelderivative/v2
AUTODESK_BUCKET_POLICY_KEY=transient
AUTODESK_MODEL_DERIVATIVE_POLL_INTERVAL_SECONDS=10
AUTODESK_MODEL_DERIVATIVE_TIMEOUT_SECONDS=1800
AUTODESK_HTTP_TIMEOUT_SECONDS=60
AUTODESK_UPLOAD_TIMEOUT_SECONDS=900

# Cloudflare R2 object storage
# Endpoint defaults to https://<ACCOUNT_ID>.r2.cloudflarestorage.com when left blank.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
